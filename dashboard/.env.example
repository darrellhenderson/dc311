# Copy to dashboard/.env.local for local overrides. All variables are optional.
# CI sets VITE_BASE_PATH and VITE_GITHUB_REPO_URL automatically from repo vars.

# Base path for production deploys (e.g. /311-dc/). Falls back to / for local dev.
VITE_BASE_PATH=

# GitHub repo URL shown in the About panel.
VITE_GITHUB_REPO_URL=

# Optional portfolio metadata; defaults live in dashboard/src/lib/site.ts.
VITE_AUTHOR_NAME=
VITE_GITHUB_PROFILE_URL=
VITE_LINKEDIN_URL=
